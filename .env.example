# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# Public (EXPO_PUBLIC_*) values are bundled into the client; the anon key is safe to expose,
# protect data with Supabase Row Level Security, not by hiding this key.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — used by Supabase Edge Functions only (server-side).
# Never set EXPO_PUBLIC_ on this key; it must NOT be bundled into the client.
# Set this in supabase/functions/.env or as a Supabase secret (supabase secrets set).
# SUPABASE_SERVICE_ROLE_KEY=
